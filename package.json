{
  "name": "eventlifter-core",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "next dev -p 3000 -H 127.0.0.1",
    "dev:api": "tsx watch backend/src/index.ts",
    "build": "next build",
    "start": "concurrently -n web,api -c blue,green \"npm run start:web\" \"npm run start:api\"",
    "start:web": "next start",
    "start:api": "tsx backend/src/index.ts",
    "migrate": "tsx backend/src/db/migrate.ts",
    "migrate:fresh": "tsx backend/src/db/migrate-fresh.ts",
    "lint": "eslint"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mysql2": "^3.22.5",
    "next": "16.2.9",
    "nodemailer": "^9.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.19.3",
    "typescript": "^5"
  }
}
