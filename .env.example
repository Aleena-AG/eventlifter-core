# Optional: explicit settings file path (VPS default: ./settings.json)
# SETTINGS_FILE=/var/www/eventlifter-core/settings.json

# Luma (optional — can also set in Settings UI; env wins if both are set)
# LUMA_API_KEY=""
# LUMA_CALENDAR_ID=""
# LUMA_API_BASE_URL="https://public-api.luma.com"
# LUMA_DISCOVER_BASE_URL="https://api.lu.ma"

# Eventbrite OAuth (optional — can also set in Settings UI)
# EVENTBRITE_CLIENT_ID=""
# EVENTBRITE_CLIENT_SECRET=""
# EVENTBRITE_REDIRECT_URI="https://www.ewentcast.com/api/eventbrite/callback"
# EVENTBRITE_PRIVATE_TOKEN=""

# HighTribe (optional — can also set in Settings UI)
# HIGHTRIBE_SERVICE_URL=""
# HIGHTRIBE_API_KEY=""
# HIGHTRIBE_WEBHOOK_SECRET=""
# HT_API_BASE=https://api.hightribe.com
