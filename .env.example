# Optional: explicit settings file path (VPS default: ./settings.json)
# SETTINGS_FILE=/var/www/eventlifter-core/settings.json

# Luma (optional — can also set in Settings UI; env wins if both are set)
# LUMA_API_KEY=""
# LUMA_CALENDAR_ID=""
# LUMA_API_BASE_URL="https://public-api.luma.com"
# LUMA_DISCOVER_BASE_URL="https://api.lu.ma"

# Eventbrite OAuth (optional — can also set in Settings UI)
# EVENTBRITE_CLIENT_ID=""
# EVENTBRITE_CLIENT_SECRET=""
# EVENTBRITE_REDIRECT_URI="https://www.ewentcast.com/api/eventbrite/callback"
# EVENTBRITE_PRIVATE_TOKEN=""

# HighTribe (optional — can also set in Settings UI)
# HIGHTRIBE_SERVICE_URL=""
# HIGHTRIBE_API_KEY=""
# HIGHTRIBE_WEBHOOK_SECRET=""
# HT_API_BASE=https://api.hightribe.com

# Channel Manager MySQL (RDS) — set in .env.local only, never commit real values
# CHANNEL_MANAGER_DB_HOST=
# CHANNEL_MANAGER_DB_PORT=3306
# CHANNEL_MANAGER_DB_USER=
# CHANNEL_MANAGER_DB_PASSWORD=
# CHANNEL_MANAGER_DB_NAME=channel_manager_db
# DB_HEALTH_TOKEN=your-random-test-token

# AUTH_EXPOSE_RESET_TOKEN=true
# AUTH_RESET_TOKEN_HOURS=2

# SMTP (Mailtrap / production mail) — password reset emails
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=your-mailtrap-user
# SMTP_PASS=your-mailtrap-pass
# SMTP_FROM=Ewentcast <noreply@ewentcast.com>

# Public site — production default: https://ewentcast.com
# Local Laragon: APP_URL=https://eventlifter-core.test
APP_URL=https://ewentcast.com
#
# Vercel: API runs inside Next.js — no Express port, no BACKEND_URL.
# Local optional: npm run dev:api (legacy) or only npm run dev:web if DB env is set.
BACKEND_PORT=4000

# Billing — new signups get a 14-day trial (status: trialing). Do NOT set on production.
# EWENTCAST_SKIP_PAYMENT=true
# EWENTCAST_TRIAL_DAYS=14
