# Optional: explicit settings file path (VPS default: ./settings.json)
# SETTINGS_FILE=/var/www/eventlifter-core/settings.json

# Separated backend API (auth, settings, events, registry, webhooks)
BACKEND_URL=https://ewentcast-backend.vercel.app
# Browser calls this directly (Network tab shows this host). Must match BACKEND_URL.
NEXT_PUBLIC_BACKEND_URL=https://ewentcast-backend.vercel.app

# Luma (optional — can also set in Settings UI; env wins if both are set)
# LUMA_API_KEY=""
# LUMA_CALENDAR_ID=""
# LUMA_API_BASE_URL="https://public-api.luma.com"
# LUMA_DISCOVER_BASE_URL="https://api.lu.ma"

# Eventbrite OAuth (optional — can also set in Settings UI)
# EVENTBRITE_CLIENT_ID=""
# EVENTBRITE_CLIENT_SECRET=""
# EVENTBRITE_REDIRECT_URI="https://www.ewentcast.com/api/eventbrite/callback"
# EVENTBRITE_PRIVATE_TOKEN=""

# HighTribe (optional — can also set in Settings UI)
# HIGHTRIBE_SERVICE_URL=""
# HIGHTRIBE_API_KEY=""
# HIGHTRIBE_WEBHOOK_SECRET=""
# HT_API_BASE=https://api.hightribe.com
# HIGHTRIBE_APP_URL=https://hightribe.com
# NEXT_PUBLIC_HIGHTRIBE_APP_URL=https://hightribe.com
# SSO bridge page on HighTribe that posts the logged-in token back via postMessage
# NEXT_PUBLIC_HIGHTRIBE_SSO_PATH=/sso/ewentcast-token

# Secret URL to view webhook logs at /wh/<token> (optional; logs live on remote API)
# WEBHOOK_LOG_TOKEN=your-long-random-string-here

# Google Maps (event create location picker)
# Enable in Google Cloud Console for the same project as the key:
#   - Maps JavaScript API
#   - Places API  (legacy — autocomplete + place details)
#   - Geocoding API
# Places API (New) is NOT required.
# Restrict the key by HTTP referrer in Google Cloud Console
# NEXT_PUBLIC_GOOGLE_LOCATION_API_KEY=
# Optional Mapbox token (unused by create flow; kept for other map features)
# NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Public site — production default: https://ewentcast.com
# Local Laragon: APP_URL=https://eventlifter-core.test
APP_URL=https://ewentcast.com

# Billing trial hints (owned by remote API)
# EWENTCAST_TRIAL_DAYS=14
# EWENTCAST_REFUND_DAYS=14

# Stripe keys are configured on the remote backend — not required in this frontend app.
# STRIPE_PUBLISHABLE_KEY=pk_test_...
