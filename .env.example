# SQLite database folder (default: ./data relative to app root)
# Production — use absolute path:
# DATA_DIR=/var/www/eventlifter-core/data

# HighTribe API base (optional fallback if not set in Settings UI)
# HT_API_BASE=https://api.hightribe.com

# Eventbrite OAuth (optional — can also set in Settings UI / SQLite)
# EVENTBRITE_CLIENT_ID=""
# EVENTBRITE_CLIENT_SECRET=""
# EVENTBRITE_REDIRECT_URI="https://www.ewentcast.com/api/eventbrite/callback"
